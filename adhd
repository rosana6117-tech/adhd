<script>
"use strict";

/* ───────────────────────── 문항 (ASRS-v1.1, 18) ───────────────────────── */
/* group: IA(주의력결핍) / HI(과잉행동·충동) | partA: 핵심 선별 6문항의 채점역치(2 또는 3) */
const QUESTIONS = [
  {t:"어떤 일의 어려운 부분을 끝낸 뒤, 마무리 단계의 세부사항을 처리하는 데 어려움을 느끼는 일이 얼마나 자주 있습니까?", g:"IA", partA:2},
  {t:"체계적으로 정리해야 하는 일을 할 때, 순서대로 정돈하는 데 어려움을 느끼는 일이 얼마나 자주 있습니까?", g:"IA", partA:2},
  {t:"약속이나 해야 할 일을 기억하는 데 어려움을 느끼는 일이 얼마나 자주 있습니까?", g:"IA", partA:2},
  {t:"깊이 생각해야 하는 일이 있을 때, 시작을 미루거나 회피하는 일이 얼마나 자주 있습니까?", g:"IA", partA:3},
  {t:"오래 앉아 있어야 할 때, 손발을 꼼지락거리거나 몸을 뒤척이는 일이 얼마나 자주 있습니까?", g:"HI", partA:3},
  {t:"마치 모터가 달린 것처럼 과도하게 활동적이고, 무언가를 하지 않으면 안 될 것 같은 느낌이 드는 일이 얼마나 자주 있습니까?", g:"HI", partA:3},
  {t:"지루하거나 어려운 일을 할 때, 부주의한 실수를 하는 일이 얼마나 자주 있습니까?", g:"IA", partA:null},
  {t:"지루하거나 반복적인 일을 할 때, 주의를 유지하기 어려운 일이 얼마나 자주 있습니까?", g:"IA", partA:null},
  {t:"상대가 직접 말을 걸어도, 그 말에 집중하기 어려운 일이 얼마나 자주 있습니까?", g:"IA", partA:null},
  {t:"집이나 직장에서 물건을 잘못 두거나, 찾는 데 어려움을 느끼는 일이 얼마나 자주 있습니까?", g:"IA", partA:null},
  {t:"주변의 활동이나 소음 때문에 주의가 흐트러지는 일이 얼마나 자주 있습니까?", g:"IA", partA:null},
  {t:"회의 등 앉아 있어야 하는 상황에서, 자리를 뜨는 일이 얼마나 자주 있습니까?", g:"HI", partA:null},
  {t:"안절부절못하거나 들떠 있는 느낌이 드는 일이 얼마나 자주 있습니까?", g:"HI", partA:null},
  {t:"혼자 여유 있는 시간이 있을 때, 긴장을 풀고 편히 쉬기 어려운 일이 얼마나 자주 있습니까?", g:"HI", partA:null},
  {t:"사람들과 어울릴 때, 말을 지나치게 많이 한다고 느끼는 일이 얼마나 자주 있습니까?", g:"HI", partA:null},
  {t:"대화 중에 상대가 말을 끝내기 전에, 그 문장을 대신 끝내버리는 일이 얼마나 자주 있습니까?", g:"HI", partA:null},
  {t:"차례를 기다려야 하는 상황에서, 순서를 기다리기 어려운 일이 얼마나 자주 있습니까?", g:"HI", partA:null},
  {t:"다른 사람이 바쁜 상황인데도 끼어드는 일이 얼마나 자주 있습니까?", g:"HI", partA:null},
];
const OPTIONS = [
  {l:"전혀 없음", v:0},
  {l:"거의 없음", v:1},
  {l:"가끔", v:2},
  {l:"자주", v:3},
  {l:"매우 자주", v:4},
];

/* 중증도 정의 */
const TIERS = {
  normal:   {key:"normal",   name:"정상 범위",       color:"var(--c-normal)",   short:"정상",   pos:6},
  caution:  {key:"caution",  name:"경계 · 주의 관찰", color:"var(--c-caution)",  short:"주의",   pos:30},
  suspect:  {key:"suspect",  name:"ADHD 의심",       color:"var(--c-suspect)",  short:"의심",   pos:55},
  moderate: {key:"moderate", name:"중등도",          color:"var(--c-moderate)", short:"중등도", pos:80},
  severe:   {key:"severe",   name:"중증",            color:"var(--c-severe)",   short:"중증",   pos:95},
};
const TIER_ORDER = ["normal","caution","suspect","moderate","severe"];

/* ───────────────────────── 채점 로직 ───────────────────────── */
function score(ans){
  let total=0, ia=0, hi=0, partAMarks=0;
  for(let i=0;i<QUESTIONS.length;i++){
    const v = ans[i]??0;
    total += v;
    if(QUESTIONS[i].g==="IA") ia+=v; else hi+=v;
    if(QUESTIONS[i].partA!==null && v>=QUESTIONS[i].partA) partAMarks++;
  }
  const partAPositive = partAMarks>=4;
  let tier;
  if(!partAPositive){
    tier = total<=16 ? "normal" : "caution";
  }else{
    if(total<36) tier="suspect";
    else if(total<50) tier="moderate";
    else tier="severe";
  }
  // 우세 양상 (DSM-5 발현 유형 참고)
  const iaHigh = ia>=17, hiHigh = hi>=17;
  let pres;
  if(tier==="normal"){ pres="해당 없음"; }
  else if(iaHigh && hiHigh) pres="복합형 경향";
  else if(ia-hi>=6) pres="주의력결핍 우세형 경향";
  else if(hi-ia>=6) pres="과잉행동·충동 우세형 경향";
  else pres="복합형 경향";
  return {total, ia, hi, partAMarks, partAPositive, tier, pres};
}

/* ───────────────────────── 해석 텍스트 ───────────────────────── */
function interpret(s){
  const T = TIERS[s.tier];
  const lines = {
    normal:   `현재 응답에서는 ADHD 핵심 증상이 두드러지지 않습니다. 총점 <b>${s.total}점(72점 만점)</b>은 일반적인 범위에 속하며, 핵심 선별문항(Part A)에서도 기준을 넘지 않았습니다.`,
    caution:  `핵심 선별 기준은 넘지 않았지만, 총점 <b>${s.total}점</b>으로 일부 항목에서 어려움이 관찰됩니다. 임상적 ADHD라기보다는 <b>상황·피로·스트레스</b>의 영향일 수 있으니, 일상에 지장이 반복되는지 관찰해 보시기 바랍니다.`,
    suspect:  `핵심 선별문항(Part A)에서 <b>${s.partAMarks}개</b>가 기준에 해당해, 성인 ADHD 증상과 <b>일관된 양상</b>을 보입니다. 총점 <b>${s.total}점</b> 수준으로, 전문의 평가를 통해 확인해 볼 가치가 있습니다.`,
    moderate: `핵심 선별 양성에 더해 총점 <b>${s.total}점</b>으로 증상의 빈도·강도가 <b>중등도</b> 수준입니다. 업무·학업·대인관계 등 여러 영역에서 어려움이 동반될 가능성이 높습니다.`,
    severe:   `핵심 선별 양성이며 총점 <b>${s.total}점</b>으로 증상이 <b>광범위하고 강하게</b> 나타나고 있습니다. 일상 기능에 상당한 영향을 줄 수 있어, 가능한 한 빠른 전문 평가를 권합니다.`,
  };
  const profile =
    s.pres==="해당 없음" ? `두 증상군 모두 두드러지지 않습니다.`
    : s.pres==="주의력결핍 우세형 경향" ? `<b>주의력결핍</b>(부주의·집중 유지·정리·기억) 쪽이 더 두드러집니다.`
    : s.pres==="과잉행동·충동 우세형 경향" ? `<b>과잉행동·충동</b>(안절부절·말 끼어들기·기다리기 어려움) 쪽이 더 두드러집니다.`
    : `<b>주의력결핍과 과잉행동·충동</b>이 함께 나타나는 복합형 경향입니다.`;

  const p = [];
  p.push(`<p>${lines[s.tier]}</p>`);
  p.push(`<p>증상 양상을 보면, ${profile} 단, ADHD 진단은 <b>12세 이전 발병</b>, <b>두 곳 이상의 환경에서의 지장</b>, 다른 원인 배제 등을 함께 따져야 하므로, 이 검사만으로 단정할 수는 없습니다.</p>`);
  return p.join("");
}

