  return base[tier];
}

function tagsFor(s){
  const t=[];
  t.push("Part A · " + (s.partAPositive ? "양성" : "음성"));
  if(s.pres!=="해당 없음") t.push(s.pres);
  if(s.ia>=24) t.push("부주의 강함");
  if(s.hi>=24) t.push("과잉·충동 강함");
  if(s.tier==="normal") t.push("일반 범위");
  return t;
}

/* ───────────────────────── 저장소 (Firebase REST + 로컬) ───────────────────────── */
const LS_DB="adhd_db_url", LS_LOCAL="adhd_local_results", LS_NICK="adhd_nick";
function dbUrl(){ return (localStorage.getItem(LS_DB)||"").replace(/\/+$/,""); }
function isShared(){ return !!dbUrl(); }
function safeKey(name){ return (name||"익명").trim().replace(/[.#$\[\]\/\s]+/g,"_").slice(0,40) || "익명"; }

async function saveResult(rec){
  if(isShared()){
    try{
      await fetch(`${dbUrl()}/adhd_results/${safeKey(rec.nickname)}.json`,{
        method:"PUT", headers:{"Content-Type":"application/json"}, body:JSON.stringify(rec)
      });
      return;
    }catch(e){ /* 실패 시 로컬 폴백 */ }
  }
  const all = JSON.parse(localStorage.getItem(LS_LOCAL)||"{}");
  all[safeKey(rec.nickname)] = rec;
  localStorage.setItem(LS_LOCAL, JSON.stringify(all));
}
async function loadResults(){
  if(isShared()){
    try{
      const r = await fetch(`${dbUrl()}/adhd_results.json`);
      const d = await r.json();
      return d ? Object.values(d) : [];
    }catch(e){ return null; } // null = 연결 실패
  }
  const all = JSON.parse(localStorage.getItem(LS_LOCAL)||"{}");
  return Object.values(all);
}
async function resetResults(){
  if(isShared()){
    try{ await fetch(`${dbUrl()}/adhd_results.json`,{method:"DELETE"}); }catch(e){}
  }
  localStorage.removeItem(LS_LOCAL);
}

/* ───────────────────────── 상태/라우팅 ───────────────────────── */
const state = { idx:0, ans:new Array(18).fill(null), nick:"" };
const $ = id => document.getElementById(id);
function show(name){
  document.querySelectorAll(".screen").forEach(s=>s.classList.remove("active"));
  $("screen-"+name).classList.add("active");
  window.scrollTo({top:0,behavior:"smooth"});
}

/* 시작 */
$("nick").value = localStorage.getItem(LS_NICK)||"";
$("startBtn").onclick = ()=>{
  const n = $("nick").value.trim();
  if(!n){ $("nick").focus(); $("nick").style.borderColor="var(--c-severe)"; setTimeout(()=>$("nick").style.borderColor="",1200); return; }
  state.nick = n; localStorage.setItem(LS_NICK,n);
  state.idx=0; state.ans=new Array(18).fill(null);
  renderQ(); show("test");
};
$("seeDist").onclick = ()=>{ renderDist(); show("dist"); };
$("navDist").onclick = ()=>{ renderDist(); show("dist"); };

/* ── 검사 렌더 ── */
function renderQ(){
  const i=state.idx, q=QUESTIONS[i];
  $("qCur").textContent=i+1;
  $("qNum").textContent="문항 "+String(i+1).padStart(2,"0");
  $("qText").textContent=q.t;
  $("qPart").textContent = i<6 ? "Part A · 핵심 선별" : "Part B · 추가 평가";
  $("qFill").style.width = ((i)/18*100)+"%";
  const wrap=$("qOpts"); wrap.innerHTML="";
  OPTIONS.forEach(o=>{
    const b=document.createElement("button");
    b.className="opt"+(state.ans[i]===o.v?" sel":"");
    b.innerHTML=`<span class="dot"></span><span>${o.l}</span><span class="scale">${o.v}</span>`;
    b.onclick=()=>{
      state.ans[i]=o.v;
      [...wrap.children].forEach(c=>c.classList.remove("sel"));
      b.classList.add("sel");
      $("nextBtn").disabled=false;
      setTimeout(()=>{ if(state.idx<17){ next(); } }, 230);
    };
    wrap.appendChild(b);
  });
  $("nextBtn").disabled = state.ans[i]===null;
  $("nextBtn").textContent = i===17 ? "결과 보기" : "다음";
  $("backBtn").style.visibility = i===0 ? "hidden" : "visible";
}
function next(){
  if(state.ans[state.idx]===null) return;
  if(state.idx<17){ state.idx++; renderQ(); }
  else finish();
}
$("nextBtn").onclick=next;
$("backBtn").onclick=()=>{ if(state.idx>0){ state.idx--; renderQ(); } };

/* ── 결과 ── */
async function finish(){
  $("qFill").style.width="100%";
  const s=score(state.ans);
  const T=TIERS[s.tier];
  // 배지/타이틀
  $("resBadge").innerHTML=`<span style="width:8px;height:8px;border-radius:50%;background:${T.color}"></span>${T.short} · ${state.nick}`;
  $("resBadge").style.background = tint(T.color);
  $("resBadge").style.color = T.color;
  $("resTier").textContent=T.name;
  $("resTier").style.color=T.color;
  $("resLine").innerHTML = lineFor(s);
  // 스펙트럼 마커
  const pct = Math.min(97, Math.max(3, s.total/72*100));
  setTimeout(()=>$("resMarker").style.left=pct+"%", 120);
  // 점수
  $("scTotal").innerHTML=`${s.total}<span>/72</span>`;
  $("scIA").innerHTML=`${s.ia}<span>/36</span>`;
  $("scHI").innerHTML=`${s.hi}<span>/36</span>`;
  // 서브바
  $("iaVal").textContent=`${s.ia} / 36`;
  $("hiVal").textContent=`${s.hi} / 36`;
  setTimeout(()=>{
    $("iaFill").style.width=(s.ia/36*100)+"%"; $("iaFill").style.background=barColor(s.ia);
    $("hiFill").style.width=(s.hi/36*100)+"%"; $("hiFill").style.background=barColor(s.hi);
  },150);
  // 태그
  $("resTags").innerHTML = tagsFor(s).map(t=>`<span class="tag">${t}</span>`).join("");
  // 선별 요약
  $("scrPill").textContent=`${s.partAMarks}`;
  $("scrPill").style.background = s.partAPositive ? "var(--c-suspect)" : "var(--c-normal)";
  $("scrTxt").innerHTML = `<b>핵심 선별 ${s.partAPositive?"양성":"음성"}</b>6개 핵심문항 중 ${s.partAMarks}개 해당 (4개 이상이면 양성)`;
  // 해석/권장
  $("resAnalysis").innerHTML=interpret(s);
  $("resRecs").innerHTML=recsFor(s.tier).map(r=>`<li><span class="ic">✓</span><span>${r}</span></li>`).join("");
  show("result");
  // 저장
  await saveResult({
    nickname: state.nick, tier:s.tier, total:s.total, ia:s.ia, hi:s.hi,
    partAMarks:s.partAMarks, partAPositive:s.partAPositive, pres:s.pres, ts:Date.now()
  });
}
function lineFor(s){
  const m={
    normal:"ADHD 핵심 증상이 두드러지지 않는 일반 범위예요.",
    caution:"일부 어려움이 보이지만 핵심 선별 기준은 넘지 않았어요.",
    suspect:"성인 ADHD 증상과 일관된 양상이 보여요. 전문 평가를 권해요.",
    moderate:"증상이 중등도 수준이에요. 전문의 상담을 권합니다.",
    severe:"증상이 광범위하고 강해요. 빠른 전문 평가를 권합니다.",
  };
  return m[s.tier];
}
function barColor(v){ return v>=24?"var(--c-suspect)":v>=14?"var(--c-caution)":"var(--c-normal)"; }
function tint(c){
  const map={"var(--c-normal)":"#EAF4EF","var(--c-caution)":"#FAF3E3","var(--c-suspect)":"#FAEEE4","var(--c-moderate)":"#F8ECE6","var(--c-severe)":"#F8E9EA"};
  return map[c]||"#F1F3F6";
}
$("resDist").onclick=()=>{ renderDist(); show("dist"); };
$("resRetake").onclick=()=>{ state.idx=0; state.ans=new Array(18).fill(null); show("home"); };

/* ── 표본/분포 ── */
async function renderDist(){
  // 모드칩
  const chip=$("modeChip"), txt=$("modeTxt");
  if(isShared()){ chip.className="mode-chip shared"; txt.textContent="공유 모드 · 단톡방 표본"; }
  else { chip.className="mode-chip local"; txt.textContent="로컬 모드 · 이 기기 저장"; }

  const body=$("distBody");
  body.innerHTML=`<div class="card" style="text-align:center;color:var(--faint);padding:32px">불러오는 중…</div>`;
  const data = await loadResults();

  if(data===null){
    body.innerHTML=`<div class="card empty"><svg viewBox="0 0 24 24" fill="none"><path d="M12 9v4M12 17h.01M10.3 3.9 2.4 18a2 2 0 001.7 3h15.8a2 2 0 001.7-3L13.7 3.9a2 2 0 00-3.4 0z" stroke="currentColor" stroke-width="1.7"/></svg><p>공유 서버에 연결하지 못했어요.<br/>설정에서 Firebase 주소를 확인해 주세요.</p></div>`;
    return;
  }
  if(!data.length){
    body.innerHTML=`<div class="card empty"><svg viewBox="0 0 24 24" fill="none"><path d="M9 17v-6M15 17v-3M3 5h18M5 5v14a2 2 0 002 2h10a2 2 0 002-2V5" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/></svg><p>아직 참여자가 없어요.<br/>첫 검사를 진행해 보세요.</p></div>`;
    return;
  }

  // 정렬: 총점 높은 순
  data.sort((a,b)=>b.total-a.total);
  const n=data.length;
  const avg = Math.round(data.reduce((s,d)=>s+d.total,0)/n);
  const avgIA = Math.round(data.reduce((s,d)=>s+d.ia,0)/n);
  const avgHI = Math.round(data.reduce((s,d)=>s+d.hi,0)/n);
  const counts={normal:0,caution:0,suspect:0,moderate:0,severe:0};
  data.forEach(d=>counts[d.tier]=(counts[d.tier]||0)+1);
  const flagged = counts.suspect+counts.moderate+counts.severe;
  const maxC = Math.max(...Object.values(counts),1);

  let html="";
  // 요약 통계
  html += `<div class="stat-row">
    <div class="stat-cell"><div class="v">${n}<small>명</small></div><div class="k">참여자</div></div>
    <div class="stat-cell"><div class="v">${avg}<small>점</small></div><div class="k">평균 총점 (72점 만점)</div></div>
    <div class="stat-cell"><div class="v">${flagged}<small>명</small></div><div class="k">의심+ (선별 양성권)</div></div>
    <div class="stat-cell"><div class="v" style="font-size:21px">${avgIA}<small> / </small>${avgHI}</div><div class="k">평균 부주의 / 과잉·충동</div></div>
  </div>`;

  // 분포 차트
  html += `<div class="card"><p class="sect-label">중증도 분포</p>`;
  TIER_ORDER.forEach(k=>{
    const T=TIERS[k], c=counts[k]||0, w=c/maxC*100, pc=Math.round(c/n*100);
    html += `<div class="distbar">
      <div class="distbar-label"><span class="sw" style="background:${T.color}"></span>${T.name}</div>
      <div class="distbar-track"><div class="distbar-fill" style="background:${T.color};width:${c?w:0}%"></div></div>
      <div class="distbar-n">${c}명 · ${pc}%</div>
    </div>`;
  });
  html += `</div>`;

  // 참여자 목록
  html += `<div class="card"><p class="sect-label">참여자 (총점 높은 순)</p>`;
  data.forEach((d,i)=>{
    const T=TIERS[d.tier];
    html += `<div class="member" data-i="${i}">
      <div class="av" style="background:${T.color}">${escapeHtml((d.nickname||"?").slice(0,1))}</div>
      <div class="info">
        <div class="nm">${escapeHtml(d.nickname||"익명")}</div>
        <div class="meta">${dateStr(d.ts)} · 부주의 ${d.ia} / 과잉·충동 ${d.hi}</div>
      </div>
      <span class="tierbadge" style="background:${tint(T.color)};color:${T.color}">${T.short}</span>
      <span class="sc">${d.total}</span>
    </div>`;
  });
  html += `</div>`;

  // 관리
  html += `<button class="btn btn-ghost btn-sm" id="distReset" style="margin-top:4px;color:var(--c-severe)">표본 전체 초기화</button>`;

  body.innerHTML=html;

  // 멤버 클릭 → 상세
  body.querySelectorAll(".member").forEach(el=>{
    el.onclick=()=>openMember(data[+el.dataset.i]);
  });
  $("distReset").onclick=async()=>{
    if(confirm("표본 전체를 삭제할까요? 되돌릴 수 없습니다.")){
      await resetResults(); renderDist();
    }
  };
}
function openMember(d){
  const T=TIERS[d.tier];
  $("memBody").innerHTML=`
    <div class="modal-grip"></div>
    <div style="display:flex;align-items:center;gap:13px;margin-bottom:18px">
      <div class="av" style="width:46px;height:46px;border-radius:13px;font-size:18px;background:${T.color}">${escapeHtml((d.nickname||"?").slice(0,1))}</div>
      <div><div style="font-size:18px;font-weight:700">${escapeHtml(d.nickname||"익명")}</div>
      <div style="font-size:12.5px;color:var(--faint)">${dateStr(d.ts)} 검사</div></div>
      <span class="tierbadge" style="margin-left:auto;background:${tint(T.color)};color:${T.color};font-size:13px;padding:7px 13px">${T.name}</span>
    </div>
    <div class="spectrum" style="margin:6px 0 18px"><div class="spectrum-bar lg"><div class="spectrum-marker" style="left:${Math.min(97,Math.max(3,d.total/72*100))}%"></div></div>
      <div class="spectrum-labels"><span>정상</span><span>주의</span><span>의심</span><span>중등도</span><span>중증</span></div></div>
    <div class="score-grid">
      <div class="score-cell"><div class="v">${d.total}<span>/72</span></div><div class="k">총점</div></div>
      <div class="score-cell"><div class="v">${d.ia}<span>/36</span></div><div class="k">주의력결핍</div></div>
      <div class="score-cell"><div class="v">${d.hi}<span>/36</span></div><div class="k">과잉·충동</div></div>
    </div>
    <div style="margin-top:14px;font-size:13px;color:var(--ink-2);line-height:1.6">
      핵심 선별(Part A) <b>${d.partAPositive?"양성":"음성"}</b> · 6문항 중 ${d.partAMarks}개 해당.
      증상 양상은 <b>${d.pres||"-"}</b>입니다.
    </div>`;
  $("memModal").classList.add("open");
}

$("distHome").onclick=()=>show("home");
$("distRefresh").onclick=renderDist;

/* ── 설정 모달 ── */
$("navSet").onclick=()=>{ $("dbUrl").value=dbUrl(); $("setModal").classList.add("open"); };
$("setCancel").onclick=()=>$("setModal").classList.remove("open");
$("setSave").onclick=()=>{
  const u=$("dbUrl").value.trim();
  if(u) localStorage.setItem(LS_DB,u); else localStorage.removeItem(LS_DB);
  $("setModal").classList.remove("open");
};

/* ── 안내 모달 ── */
