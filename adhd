  <p>개인정보는 닉네임과 점수만 저장되며, 실명·연락처 등은 수집하지 않습니다.</p>`;
function openInfo(title,html){ $("infoTitle").textContent=title; $("infoBody").innerHTML=html; $("infoModal").classList.add("open"); }
$("aboutLink").onclick=()=>openInfo("검사·채점 방식",ABOUT_HTML);
$("distAbout").onclick=()=>openInfo("표본 저장 방식",STORE_HTML);
$("infoClose").onclick=()=>$("infoModal").classList.remove("open");
$("memClose").onclick=()=>$("memModal").classList.remove("open");
document.querySelectorAll(".modal-bg").forEach(m=>m.addEventListener("click",e=>{ if(e.target===m) m.classList.remove("open"); }));

/* ── 유틸 ── */
function escapeHtml(s){ return (s+"").replace(/[&<>"']/g,c=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[c])); }
function dateStr(ts){
  if(!ts) return "-";
  const d=new Date(ts);
  return `${d.getMonth()+1}월 ${d.getDate()}일`;
}
